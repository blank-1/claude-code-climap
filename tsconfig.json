{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": false,
        "skipLibCheck": true,
        "noEmit": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "types": ["bun"],
        "paths": {
            "src/*": ["./src/*"]
        },
        "ignoreDeprecations": "6.0"
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "packages/**/*.ts"],
    "exclude": ["node_modules"]
}
